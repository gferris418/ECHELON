# ECHELON Local Development Environment
# Copy to .env and fill in your values. Never commit .env files.

# PostgreSQL
POSTGRES_USER=echelon
POSTGRES_PASSWORD=change_me
POSTGRES_DB=echelon
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=echelon
MINIO_ROOT_PASSWORD=change_me
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Traefik
TRAEFIK_PORT=8080
TRAEFIK_DASHBOARD_PORT=8081

# Application
ECHELON_ENV=development
ECHELON_LOG_LEVEL=debug

# Kernel API
KERNEL_API_PORT=3000

# Mission Control
MISSION_CONTROL_PORT=3001

# Worker
WORKER_PORT=3002
